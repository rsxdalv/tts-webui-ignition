{
  "applicationId": "js.neutralino.vitetsreact",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/vite-src/dist/",
  "url": "/",
  "port": 7779,
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "filesystem.readDirectory",
    "os.execCommand",
    "os.spawnProcess",
    "os.updateSpawnedProcess",
    "events.*"
  ],
  "singlePageServe": true,
  "modes": {
    "window": {
      "title": "vite-app",
      "width": 800,
      "height": 1200,
      "minWidth": 400,
      "minHeight": 200,
      "icon": "/vite-src/public/logo512.png",
      "enableInspector": true
    }
  },
  "cli": {
    "binaryName": "vite-app",
    "resourcesPath": "/vite-src/dist/",
    "extensionsPath": "/extensions/",
    "frontendLibrary": {
      "patchFile": "/vite-src/index.html",
      "devUrl": "http://localhost:5173",
      "projectPath": "/vite-src/",
      "initCommand": "npm install",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build"
    },
    "binaryVersion": "6.7.0"
  }
}